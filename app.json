{
  "expo": {
    "name": "SwiftPay",
    "slug": "swiftpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#4F46E5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swiftpay.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "SwiftPay uses Face ID to securely authenticate you.",
        "NSCameraUsageDescription": "SwiftPay needs camera access to scan QR codes for payments.",
        "NSLocationWhenInUseUsageDescription": "SwiftPay needs your location to find nearby ATMs and banks."
      }
    },
    "android": {
      "package": "com.swiftpay.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow SwiftPay to use Face ID for secure login."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SwiftPay to access your camera to scan QR codes for payments."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SwiftPay to use your location to find nearby ATMs and banks."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "fc836b18-3fdb-4e3a-abc7-408fc2fc8f06"
      }
    }
  }
}
